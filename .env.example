# 复制为 .env；Compose 会做变量替换并传入容器（config.yaml 里 ${VAR} 亦可引用）。

WECHAT_APP_ID=
WECHAT_APP_SECRET=
APP_PORT=9090

# —— LLM（OpenAI 兼容：统一用 Chat Completions）——
# 方式 A：在 config.yaml 里写满 ai.base_url / ai.api_key / 模型名。
# 方式 B：用环境变量（优先级见 config 包 resolveAIAPIKeyFromEnv）；可配合 ${AI_API_KEY} 等占位符。

# 选填：未在 yaml 写 base_url 时用（须以 /v1 结尾，无尾斜杠问题程序会规范化）
# AI_BASE_URL=https://api.openai.com/v1

# API Key 任选其一设置即可（程序按序回退）：AI_API_KEY > LLM_API_KEY > OPENROUTER_API_KEY > DEEPSEEK_API_KEY > OPENAI_API_KEY
AI_API_KEY=
# OPENROUTER_API_KEY=sk-or-v1-...
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# OpenRouter 可选（排名统计）：https://openrouter.ai/docs
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_X_TITLE=onepaper

# —— 复用外部 MySQL（默认 docker-compose.yml）——
EXTERNAL_MYSQL_NETWORK=slowwindow_slowwindow-network
DB_ROOT_PASSWORD=
DB_USER=
DB_PASSWORD=

# —— 可选：独立 MySQL（docker-compose.local-mysql.yml）——
# MYSQL_ROOT_PASSWORD=onepaper
# MYSQL_DATA_DIR=./data/mysql
# MYSQL_PORT=3306
