# 复制为 .env 后填写；docker compose 会读此文件做变量替换，并把部分变量传入 onepaper 容器。

OPENAI_API_KEY=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
APP_PORT=9090

# —— 复用外部 MySQL（默认 docker-compose.yml）——
# Docker 网络名：须与对方项目 MySQL 所在网络一致（docker network ls）
EXTERNAL_MYSQL_NETWORK=slowwindow_slowwindow-network
# 与 slowwindow .env 里 DB_ROOT_PASSWORD（或 MYSQL_ROOT_PASSWORD）一致，供 config.yaml dsn 使用
DB_ROOT_PASSWORD=
# 若 dsn 使用业务账号，填写对方 DB_USER / DB_PASSWORD（且已对 onepaper 库授权）
DB_USER=
DB_PASSWORD=

# —— 可选：独立 MySQL（docker-compose.local-mysql.yml）——
# MYSQL_ROOT_PASSWORD=onepaper
# MYSQL_DATA_DIR=./data/mysql
# MYSQL_PORT=3306
